# ─────────────────────────────────────────────────────────────────────────────
# BC AI Agent — Production Environment Variables
# Copy this file to .env and fill in every value before deploying.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_RANDOM_KEY

# Comma-separated list of allowed CORS origins (your public domain)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Database (PostgreSQL via Docker Compose) ──────────────────────────────────
# These are used by both the 'db' service and the 'backend' service.
POSTGRES_DB=bc_agent
POSTGRES_USER=bcagent
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# DATABASE_URL is built automatically in docker-compose.yml from the vars above.
# Only set this manually if you're using an external/managed database.
# DATABASE_URL=postgresql://bcagent:password@db:5432/bc_agent

# ── Business Central API ──────────────────────────────────────────────────────
BC_TENANT_ID=your-azure-tenant-id
BC_CLIENT_ID=your-bc-app-client-id
BC_CLIENT_SECRET=your-bc-app-client-secret
BC_ENVIRONMENT=Production
BC_COMPANY_ID=your-bc-company-id
BC_COMPANY_NAME=Open Distribution Company Inc.

# ── Microsoft Graph (email monitoring) ───────────────────────────────────────
GRAPH_TENANT_ID=your-azure-tenant-id
GRAPH_CLIENT_ID=your-graph-app-client-id
GRAPH_CLIENT_SECRET=your-graph-app-client-secret

# ── Anthropic Claude AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email / Notifications ─────────────────────────────────────────────────────
NOTIFICATION_SENDER_EMAIL=noreply@yourdomain.com
ADMIN_NOTIFICATION_EMAILS=joey@opendc.ca
CUSTOMER_PORTAL_URL=https://yourdomain.com/customer.html
ADMIN_PORTAL_URL=https://yourdomain.com

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_EMAIL_MONITORING=true
ENABLE_AI_PARSING=true
ENABLE_CUSTOMER_NOTIFICATIONS=true

# ── Email Inboxes (optional — add the inboxes you want monitored) ─────────────
# EMAIL_INBOX_1=quotes@yourdomain.com
# EMAIL_INBOX_2=

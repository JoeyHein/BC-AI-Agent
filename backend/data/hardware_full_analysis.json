  "patterns": {
    "HK_complete_kits": {
      "format": "HKnn-00000-XX",
      "nn_meaning": "Kit tier/size (01=smallest, 06=largest)",
      "XX_codes": {
        "AL": "Aluminum hardware",
        "RC": "Standard/Steel (Residential-Commercial)"
      },
      "price_range": "$276 - $1167"
    },
    "HK10_purchased_boxes": {
      "format": "HK10-0HHSS-WWWW",
      "HH_meaning": "Door height in feet (07=7ft, 08=8ft)",
      "SS_meaning": "Number of sections (04=4 sections)",
      "WWWW_codes": {
        "0809": "8-10 feet wide (narrow residential, 3 hinges per section)",
        "1316": "12-18 feet wide (wide/double, 5 hinges per section)"
      },
      "track_type": "2R (2-inch Residential track)",
      "description_codes": {
        "4S3HW": "4 Sections, 3 Hinges Width (narrow doors)",
        "4S5HW": "4 Sections, 5 Hinges Width (wide doors)"
      },
      "price_range": "$110 - $138"
    },
    "HW_commercial_boxes": {
      "format": "HWww-hhhhh-00",
      "ww_meaning": "Door width in feet (08, 10, 12, 14, 16, 18)",
      "hhhhh_meaning": "Door height encoded (08000=8ft, 10000=10ft, etc.)",

{
  "version": "1.0.0",
  "created": "2026-01-23",
  "description": "Quick reference mapping guide for BC part numbers - derived from analysis of 11,369 items and 891 quotes",

  "spring_mappings": {
    "description": "Maps wire_size + coil_id + wind -> BC part number",
    "format": "SP{type}-{wire}{coil}-{wind}",
    "types": {
      "SP10": "Galvanized",
      "SP11": "Oil Tempered (most common)",
      "SP16": "Pre-Pick (cut to length)"
    },
    "wire_codes": {
      "0.218": "218", "0.225": "225", "0.234": "234", "0.243": "243",
      "0.250": "250", "0.262": "262", "0.273": "273", "0.283": "283",
      "0.295": "295", "0.306": "306", "0.312": "312", "0.319": "319",
      "0.331": "331", "0.343": "343", "0.362": "362", "0.375": "375",
      "0.393": "393", "0.406": "406", "0.421": "421", "0.437": "437"
    },
    "coil_codes": {
      "2.0": "20", "2.625": "25", "3.75": "36", "6.0": "60"
    },
    "wind_codes": {"LH": "01", "RH": "02"}
  },

  "winder_stationary_sets": {
    "2.0_LH": "SP12-00231-00", "2.0_RH": "SP12-00237-00",
    "2.625_LH": "SP12-00232-00", "2.625_RH": "SP12-00238-00",
    "3.75_LH": "SP12-00233-00", "3.75_RH": "SP12-00239-00",
    "6.0_LH": "SP12-00234-00", "6.0_RH": "SP12-00240-00"
  },

  "panel_mappings": {
    "format": "PN{series}-{height}{stamp}{color}-{width}",
    "series": {"TX450_SEC": "45", "TX450_DEC": "46", "KANATA_SEC": "60"},
    "heights": {"21": "21 inch", "24": "24 inch"},
    "stamps": {"UDC": "4", "STD": "0"},
    "colors": {
      "WHITE": "00", "BROWN": "01", "BLACK": "05", "NEW BROWN": "10",
      "STEEL GREY": "20", "HAZELWOOD": "40", "WALNUT": "51"
    }
  },

  "weather_stripping": {
    "format": "PL10-{length}203-{color}",
    "lengths": ["07", "08", "09", "10", "12", "14", "16", "18"],
    "colors": {"WHITE": "00", "BLACK": "05", "NEW BROWN": "10"}
  },

  "astragal": {
    "3_inch": "PL10-00005-01",
    "4_inch": "PL10-00005-02",
    "6.5_inch": "PL10-00005-03"
  },

  "retainer": "PL10-00141-00",

  "track_format": {
    "2_inch_std_bracket": "TR02-STDBM-{height}{radius}",
    "3_inch_std_bracket": "TR03-STDBM-{height}",
    "2_inch_vertical": "TR02-VLBM-{height}",
    "3_inch_vertical": "TR03-VLBM-{height}"
  },

  "shaft_format": {
    "tube_1_inch": "SH12-1{width}10-00",
    "solid_1_inch": "SH11-1{width}06-00"
  },

  "struts_20ga": {
    "8": "FH17-00028-00", "9": "FH17-00029-00", "10": "FH17-00030-00",
    "12": "FH17-00001-00", "14": "FH17-00002-00", "16": "FH17-00003-00",
    "18": "FH17-00004-00"
  }
}

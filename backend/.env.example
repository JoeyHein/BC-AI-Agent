# BC AI Agent - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Application Settings
APP_NAME="BC AI Agent"
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Business Central API
BC_TENANT_ID=your-azure-tenant-id
BC_CLIENT_ID=your-bc-app-client-id
BC_CLIENT_SECRET=your-bc-app-client-secret
BC_ENVIRONMENT=Sandbox
BC_COMPANY_ID=your-company-id
BC_BASE_URL=https://api.businesscentral.dynamics.com/v2.0

# Microsoft Graph API (Office 365 Email)
GRAPH_TENANT_ID=your-azure-tenant-id
GRAPH_CLIENT_ID=your-graph-app-client-id
GRAPH_CLIENT_SECRET=your-graph-app-client-secret
EMAIL_INBOX_1=email1@yourcompany.com
EMAIL_INBOX_2=email2@yourcompany.com

# Anthropic Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bc_ai_agent
DATABASE_ECHO=False

# Redis (Task Queue)
REDIS_URL=redis://localhost:6379/0

# Azure Services
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
AZURE_APPLICATION_INSIGHTS_CONNECTION_STRING=your-app-insights-connection-string

# OpenPhone/Quo (Phase 1+)
OPENPHONE_API_KEY=your-openphone-api-key

# Mailchimp (Weekly Email Agent)
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_SERVER_PREFIX=us14
MAILCHIMP_AUDIENCE_ID=your-audience-id
MAILCHIMP_FROM_NAME=Joey @ OPENDC
MAILCHIMP_FROM_EMAIL=joey@opendc.com

# Feature Flags
ENABLE_EMAIL_MONITORING=True
ENABLE_AI_PARSING=True
ENABLE_VENDOR_INTELLIGENCE=True

# Logging
LOG_LEVEL=INFO
